;; Emacs looks for init files in this order: ~/.eamcs -> ~/.emacs.el -> .emacs.d/init.el
;; If not created, create it Ctrl + x & Ctrl + f type ~/.emacs or alternatives
;; Paste to newly created ~/.emacs

;; My personal preferred sizes, font, etc.
(custom-set-faces
'(default ((t (:family "Courier New" :foundry "outline" :slant normal :weight regular :height 218 :width normal)))))
(setq custom-safe-themes t)

;; Prevent default load screen from loading
(setq inhibit-startup-screen t)

;; Remove menu bar
(menu-bar-mode 0)

;; Remove tool bar
(tool-bar-mode 0)

;; Adds numbers on left side
(column-number-mode 1)
(global-display-line-numbers-mode)

 ;; Full screen mode
(push '(fullscreen . maximized) default-frame-alist)

;; Tab indent mode (when press tab button, will indent 4)
(setq-default indent-tabs-mode nil)
(setq-default tab-width 4)

(require 'package)
(add-to-list 'package-archives
             '("melpa" . "http://melpa.milkbox.net/packages/") t)
(setq gnutls-algorithm-priority "NORMAL:-VERS-TLS1.3")
(custom-set-variables
 '(custom-enabled-themes '(gruber-darker))
 '(custom-safe-themes
   '("e27c9668d7eddf75373fa6b07475ae2d6892185f07ebed037eedf783318761d7" "e13beeb34b932f309fb2c360a04a460821ca99fe58f69e65557d6c1b10ba18c7" default))
 '(package-selected-packages '(gruber-darker-theme grugru))
 '(transient-mark-mode nil))

;; Prompts to load file, no need to type
(call-interactively #'find-file)
